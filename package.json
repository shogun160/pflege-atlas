{
  "name": "pflegecommons",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@lexical/link": "0.41.0",
    "@lexical/list": "0.41.0",
    "@lexical/react": "0.41.0",
    "@lexical/utils": "0.41.0",
    "@marsidev/react-turnstile": "^1.5.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@payloadcms/db-postgres": "3.85.0",
    "@payloadcms/email-resend": "^3.85.0",
    "@payloadcms/next": "3.85.0",
    "@payloadcms/richtext-lexical": "3.85.0",
    "@payloadcms/storage-s3": "3.85.0",
    "@payloadcms/ui": "3.85.0",
    "cross-env": "^7.0.3",
    "diff": "^9.0.0",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "js-yaml": "^4.2.0",
    "lexical": "0.41.0",
    "next": "16.2.6",
    "payload": "3.85.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-easy-crop": "^6.0.2",
    "sharp": "0.34.2",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/yauzl": "^3.4.0",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "4.5.2",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "28.0.0",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.8",
    "yazl": "^3.3.1"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
