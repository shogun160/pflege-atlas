# PflegeAtlas — Beispiel-Environment.
# Kopiere als .env und passe Werte an. .env ist gitignored.
# Die Mail-Vars sind optional in Dev — leer lassen, dann läuft Payload mit Console-Logger.

# --- Datenbank (matches docker-compose.yml) ---
DATABASE_URI=postgres://pflege:pflege_dev@localhost:5432/pflegecommons

# --- Payload ---
# Beliebige lange Zufallszeichenkette für Dev; rotieren für Production.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# --- Public URL ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Mail (optional in Dev, Pflicht in Production) ---
# Wenn RESEND_API_KEY leer ist, fällt Payload auf Console-Logging zurück.
# In Production werden diese Werte aus dem Hosting-Dashboard gesetzt, nicht hier.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@pflegeatlas.org
RESEND_FROM_NAME=PflegeAtlas

# --- Test-Mail-Skript (optional) ---
# Default-Empfänger für `pnpm tsx scripts/send-test-mail.ts`, wenn kein CLI-Arg gegeben.
TEST_MAIL_TO=

# --- Turnstile (Spam-Schutz für Submission-Formular) ---
# Cloudflare-Dashboard → Turnstile → Site Key + Secret Key.
# Ohne Secret läuft Dev/CI im Bypass-Pfad (immer accept).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------
# V1.5 — GitHub-Sync (Submissions als PRs)
# Wird nur aktiv, wenn GITHUB_APP_PRIVATE_KEY gesetzt ist.
# In Production (NODE_ENV=production) sind alle drei Pflicht.
# Werte im 1Password-Eintrag "PflegeAtlas GitHub App".
# ---------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
# Base64-encoded private key (single line, ohne newlines)
GITHUB_APP_PRIVATE_KEY=
# Optional: Repo-Override (Default: shogun160 / pflege-atlas)
# GITHUB_REPO_OWNER=
# GITHUB_REPO_NAME=
